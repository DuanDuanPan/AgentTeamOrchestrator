# ATO 声明式工作流配置
# ================================
# 本文件定义系统的角色、阶段序列、转换规则和阈值参数。
# 配置变更需重启系统生效（FR51）。
#
# 使用方法：
#   cp ato.yaml.example ato.yaml
#   根据项目需求编辑 ato.yaml

# ---------------------------------------------------------------------------
# CLI 工具全局默认参数
# ---------------------------------------------------------------------------
# 所有使用该 CLI 的角色自动继承。角色级同名字段优先。
# 省略的字段由 CLI 工具自身决定默认行为。
#
# Claude -p 模式会继承 ~/.claude/settings.json 中的 model 和 effortLevel，
# 因此通常不需要在此重复配置。仅在需要覆盖时使用 cli_defaults.claude。
#
# Codex exec 模式不继承 shell alias 参数，必须在此显式声明。

cli_defaults:
  # claude:
  #   model: sonnet          # 覆盖 settings.json 默认模型
  #   effort: high           # 覆盖 settings.json effort (low/medium/high/max)
  codex:
    model: gpt-5.4
    reasoning_effort: xhigh
    reasoning_summary_format: experimental

# ---------------------------------------------------------------------------
# 角色定义
# ---------------------------------------------------------------------------
# 每个角色指定使用的 CLI 工具（claude / codex）。
# model / sandbox / effort / reasoning_effort / reasoning_summary_format
# 均为可选字段，省略时从 cli_defaults 继承，再省略则由 CLI 自身决定。
# 角色级字段优先于 cli_defaults。

roles:
  creator:
    cli: claude
  ux_designer:
    cli: claude
  validator:
    cli: codex
  developer:
    cli: claude
  reviewer:
    cli: codex
  fixer:
    cli: claude
  qa:
    cli: codex
  reviewer_escalated:
    cli: claude
  fixer_escalation:
    cli: codex
    sandbox: workspace-write

# ---------------------------------------------------------------------------
# 阶段序列
# ---------------------------------------------------------------------------
# 定义 story 生命周期的各个阶段及其转换规则。
# type 取值：structured_job | convergent_loop | interactive_session
# next_on_success: 成功后跳转的阶段（或 "done" 表示完成）
# next_on_failure: 失败后跳转的阶段（可选）
# parallel_safe: true 时走 MainPathGate 共享锁（允许多 story 并发持有）
# batchable: true 时同 phase 的多个 story 合并到单个 LLM 会话依次处理（节省上下文加载成本）

phases:
  - name: creating
    role: creator
    type: structured_job
    next_on_success: designing
    workspace: main
    parallel_safe: true
    batchable: true

  - name: designing
    role: ux_designer
    type: structured_job
    next_on_success: validating
    workspace: main
    skip_when: "not story.has_ui"
    parallel_safe: true
    batchable: true

  - name: validating
    role: validator
    type: convergent_loop
    next_on_success: dev_ready
    next_on_failure: creating
    workspace: main
    parallel_safe: true

  - name: dev_ready
    role: developer
    type: structured_job
    next_on_success: developing
    workspace: main

  - name: developing
    role: developer
    type: structured_job
    next_on_success: reviewing
    workspace: worktree

  - name: reviewing
    role: reviewer
    type: convergent_loop
    next_on_success: qa_testing
    next_on_failure: fixing
    workspace: worktree

  - name: fixing
    role: fixer
    type: structured_job
    next_on_success: reviewing
    workspace: worktree

  - name: qa_testing
    role: qa
    type: convergent_loop
    next_on_success: uat
    next_on_failure: fixing
    workspace: worktree

  - name: uat
    role: developer
    type: interactive_session
    next_on_success: merging
    next_on_failure: fixing
    workspace: worktree

  - name: merging
    role: developer
    type: structured_job
    next_on_success: regression
    workspace: main

  - name: regression
    role: qa
    type: structured_job
    next_on_success: done
    next_on_failure: fixing
    workspace: main

# ---------------------------------------------------------------------------
# 并发控制
# ---------------------------------------------------------------------------

# 最大并发 agent 数量
max_concurrent_agents: 4

# Planning 阶段（parallel_safe: true）跨 story 最大并发数
max_planning_concurrent: 3

# ---------------------------------------------------------------------------
# Convergent Loop 参数
# ---------------------------------------------------------------------------

convergent_loop:
  max_rounds: 6                     # Phase 1 最大迭代轮次（>= 1）
  max_rounds_escalated: 3           # Phase 2 梯度降级最大轮次（>= 1）
  convergence_threshold: 0.5        # 收敛阈值（0.0 ~ 1.0）

# ---------------------------------------------------------------------------
# 超时设置（秒）
# ---------------------------------------------------------------------------

timeout:
  structured_job: 1800              # 结构化任务超时：30 分钟
  interactive_session: 7200         # 交互式会话超时：2 小时

# ---------------------------------------------------------------------------
# 成本控制（可选）
# ---------------------------------------------------------------------------
# 不配置时不做预算上限控制；如需自定义预算或 blocking 阈值，再取消注释。
# cost:
#   budget_per_story: 5.0             # 每个 story 预算上限（USD）
#   blocking_threshold: 10            # 阻塞性 finding 数量阈值

# ---------------------------------------------------------------------------
# 模型覆盖映射（可选）
# ---------------------------------------------------------------------------
# 为特定阶段指定模型，优先于角色级 model（含省略/None）。
# key 必须是已定义的阶段名。
# 示例：
#   model_map:
#     reviewing: opus
#     qa_testing: codex-mini-latest

# ---------------------------------------------------------------------------
# 跨项目测试策略分层（可选）
# ---------------------------------------------------------------------------
# test_catalog 定义“抽象 layer 名 → 项目真实命令”的映射。
# phase_test_policy 定义不同 phase 如何消费这些 layer。
#
# 约束：
# - required_layers 必跑，按声明顺序执行
# - optional_layers 是候选追加层，按声明顺序尝试
# - allow_discovery 控制是否允许在声明集合外追加发现/诊断命令
# - max_additional_commands 约束单次 phase 执行尝试中的追加命令数
# - allowed_when:
#     never / after_required_commands / after_required_failure / always
#
# 推荐 layer 名：
#   bootstrap / lint / typecheck / unit / integration / system / build / smoke / package

test_catalog:
  bootstrap:
    commands:
      - "uv sync --dev"
  lint:
    commands:
      - "uv run ruff check src tests"
  typecheck:
    commands:
      - "uv run mypy src"
  unit:
    commands:
      - "uv run pytest tests/unit/"
  integration:
    commands:
      - "uv run pytest tests/integration/"
  smoke:
    commands:
      - "uv run pytest tests/smoke/"

phase_test_policy:
  qa_testing:
    required_layers:
      - lint
      - typecheck
      - unit
    optional_layers:
      - integration
      - smoke
    allow_discovery: true
    max_additional_commands: 2
    allowed_when: after_required_failure

  regression:
    required_layers:
      - bootstrap
      - unit
    optional_layers:
      - integration
      - smoke
    allow_discovery: true
    max_additional_commands: 2
    allowed_when: after_required_commands

# ---------------------------------------------------------------------------
# Merge & Regression 配置
# ---------------------------------------------------------------------------

# 回归测试基线命令（legacy fallback 示例，仅在未配置 phase_test_policy.regression 时生效）
# 如果上面的 phase_test_policy.regression 已配置，本段不会参与运行时解析。
# 需要使用 legacy baseline 时，删除 phase_test_policy.regression，再取消注释以下示例：
# regression_test_commands:
#   - "uv run pytest tests/unit/"
#   - "uv run pytest tests/integration/"
#   - "uv run pytest tests/smoke/"

# 向后兼容：单命令格式（当 regression_test_commands 存在时此字段被忽略）
# regression_test_command: "uv run pytest"

# Rebase 超时时间（秒）
merge_rebase_timeout: 120

# Agent 解决 rebase 冲突最大重试次数
merge_conflict_resolution_max_attempts: 1

model_map: {}
