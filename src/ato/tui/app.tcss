/* ATO TUI 深色主题 — Dracula 变体 9 语义色 */

/* ===== 语义色彩变量 (AC1) ===== */
$success: #50fa7b;
$warning: #f1fa8c;
$error: #ff5555;
$info: #8be9fd;
$accent: #bd93f9;
$muted: #8390b7;
$text: #f8f8f2;
$background: #282a36;
$surface: #44475a;

/* ===== 全局基础 (Task 1.2) ===== */

Screen {
    background: $background;
    color: $text;
}

/* ===== 面板基础样式 (Task 1.3) ===== */

.panel {
    border: solid $muted;
    padding: 1 2;
    margin: 0 1;
    background: $background;
}

.panel:focus-within {
    border: solid $accent;
}

/* ===== 文字层级 (Task 1.4 / AC5) ===== */

.h1 {
    text-style: bold;
    color: $accent;
}

.h2 {
    text-style: bold;
    color: $text;
}

.body {
    color: $text;
}

.secondary {
    color: $muted;
}

.emphasis {
    text-style: bold;
}

/* ===== ThreeQuestionHeader (Story 6.2a) ===== */

ThreeQuestionHeader {
    height: 1;
    background: $surface;
    color: $text;
    padding: 0 1;
}

/* ===== DashboardScreen 容器 ===== */

DashboardScreen {
    height: 1fr;
    background: $background;
}

/* ===== 三面板布局 ===== */

.three-panel-container {
    height: 1fr;
}

.left-panel {
    width: 40%;
    border: solid $muted;
    padding: 1 2;
}

.left-panel:focus-within {
    border: solid $accent;
}

.right-panel {
    width: 60%;
    border: solid $muted;
    padding: 1 2;
}

.right-panel:focus-within {
    border: solid $accent;
}

/* 超宽屏 180+ 列时由 Python 动态调整比例 */

/* ===== Tab 模式 ===== */

.tabbed-container {
    height: 1fr;
}

/* ===== 降级模式 ===== */

.degraded-container {
    height: 1fr;
    content-align: center middle;
    color: $warning;
}

/* ===== ContentSwitcher ===== */

ContentSwitcher {
    height: 1fr;
}

/* ===== StoryStatusLine / HeartbeatIndicator (Story 6.2b) ===== */

StoryStatusLine {
    height: 1;
    padding: 0 1;
}

HeartbeatIndicator {
    height: 1;
    padding: 0 1;
}

.story-row {
    height: 1;
}

.selected-story {
    background: $accent 20%;
    color: $text;
}

/* ===== ApprovalCard (Story 6.3a) ===== */

ApprovalCard {
    height: 1;
    padding: 0 1;
}

.approval-row {
    height: 1;
}

.selected-approval {
    background: $warning 15%;
    color: $text;
}

.approval-submitted {
    color: $muted;
    text-style: italic;
}

/* ===== ExceptionApprovalPanel (Story 6.3b) ===== */

ExceptionApprovalPanel {
    min-height: 8;
    padding: 1;
    border: solid $surface;
}

.exception-approval-high {
    border: solid $error;
}

.exception-approval-medium {
    border: solid $warning;
}

/* 左面板异常审批行样式 (AC4) */

.approval-exception-row {
    height: 1;
}

.approval-exception-high {
    background: $error 15%;
}

/* 数字键选项高亮 */

.exception-approval-option {
    color: $info;
    text-style: bold;
}

/* ===== StoryDetailView (Story 6.4) ===== */

StoryDetailView {
    height: 1fr;
    padding: 1;
}

#story-detail-scroll {
    height: 1fr;
}

#detail-phase-flow {
    height: auto;
    padding: 0 1;
    margin: 0 0 1 0;
    color: $text;
}

#detail-summary {
    height: auto;
    padding: 0 1;
}

#detail-cl-progress {
    height: auto;
    padding: 0 1;
}

#detail-expanded {
    height: auto;
    padding: 0 1;
    margin: 1 0 0 0;
}

/* ===== ConvergentLoopProgress (Story 6.4) ===== */

ConvergentLoopProgress {
    height: 1;
    padding: 0 1;
}

/* ===== 空状态 (Story 6.2b) ===== */

.empty-state {
    content-align: center middle;
    color: $muted;
    text-style: italic;
    height: 1fr;
}
